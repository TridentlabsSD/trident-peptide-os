{
  "framework": null,
  "buildCommand": "echo 'No build step required'",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/sw.js",
      "destination": "/sw.js"
    },
    {
      "source": "/manifest.json",
      "destination": "/manifest.json"
    },
    {
      "source": "/icon-192.png",
      "destination": "/icon-192.png"
    },
    {
      "source": "/icon-512.png",
      "destination": "/icon-512.png"
    },
    {
      "source": "/apple-touch-icon.png",
      "destination": "/apple-touch-icon.png"
    },
    {
      "source": "/api/admin",
      "destination": "/api/admin"
    },
    {
      "source": "/api/chat",
      "destination": "/api/chat"
    },
    {
      "source": "/api/stripe",
      "destination": "/api/stripe"
    },
    {
      "source": "/api/stripe-webhook",
      "destination": "/api/stripe-webhook"
    },
    {
      "source": "/api/create-subscription",
      "destination": "/api/create-subscription"
    },
    {
      "source": "/api/supabase",
      "destination": "/api/supabase"
    },
    {
      "source": "/api/affiliate",
      "destination": "/api/affiliate"
    },
    {
      "source": "/api/check-access",
      "destination": "/api/check-access"
    },
    {
      "source": "/signin",
      "destination": "/signin.html"
    },
    {
      "source": "/tracker",
      "destination": "/tracker.html"
    },
    {
      "source": "/chat",
      "destination": "/chat.html"
    },
    {
      "source": "/protocol",
      "destination": "/protocol.html"
    },
    {
      "source": "/library",
      "destination": "/library.html"
    },
    {
      "source": "/tools",
      "destination": "/tools.html"
    },
    {
      "source": "/stack",
      "destination": "/stack.html"
    },
    {
      "source": "/account",
      "destination": "/account.html"
    },
    {
      "source": "/checkout",
      "destination": "/checkout.html"
    },
    {
      "source": "/onboarding",
      "destination": "/onboarding.html"
    },
    {
      "source": "/questionnaire",
      "destination": "/questionnaire.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/rebill",
      "destination": "/rebill.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    }
  ],
  "crons": [
    {
      "path": "/api/affiliate?action=release",
      "schedule": "0 10 * * *"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    }
  ]
}
